# Скопируйте этот файл в .env и заполните своими значениями.

# Токен бота от @BotFather (пример: 123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx)
BOT_TOKEN=PUT-YOUR-TOKEN-HERE

# ID администраторов через запятую. Свой ID можно узнать у @userinfobot.
ADMIN_IDS=123456789

# Необязательно
DB_PATH=support.db
PAGE_SIZE=6
